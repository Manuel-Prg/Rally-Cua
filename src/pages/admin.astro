---
// src/pages/admin.astro  —  Panel de control
import BaseLayout from "../layouts/BaseLayout.astro";
import { PHASES, totalScore } from "../lib/mockData";
import { supabase } from "../db/supabase.js";

// ── Fetch teams + scores from Supabase ──────────────────────────
let rawTeams: any[] = [];
try {
  const { data, error } = await supabase
    .from("teams")
    .select("id, name, color, members, scores(phase_id, status, points)")
    .order("id");
  if (error) {
    console.error("Admin fetch error:", error);
  } else {
    rawTeams = data || [];
  }
} catch (e) {
  console.error("Fetch exception in admin.astro:", e);
}

const teams = (rawTeams ?? []).map((row: any) => ({
  id: row.id,
  name: row.name,
  color: row.color,
  members: Array.isArray(row.members) ? row.members : [],
  phases: [1, 2, 3, 4, 5].map((phaseId) => {
    const s = (row.scores ?? []).find((sc: any) => sc.phase_id === phaseId);
    return { phaseId, status: s?.status ?? "pending", points: s?.points ?? 0 };
  }),
}));

// Serialize for client script
const teamsJson = JSON.stringify(teams);
---

<BaseLayout title="Panel Admin" activePage="admin">
  <div class="admin-view">
    <!-- ── HEADER ── -->
    <header class="admin-header">
      <div>
        <p class="admin-eyebrow">Panel de control</p>
        <h1 class="admin-title">Actualizar Marcador</h1>
      </div>
      <div class="header-actions">
        <button class="btn btn-export" id="btn-export">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
              points="7 10 12 15 17 10"></polyline><line
              x1="12"
              y1="15"
              x2="12"
              y2="3"></line>
          </svg>
          Exportar Excel
        </button>
        <button class="btn btn-primary" id="btn-register">
          + Registrar Equipo
        </button>
      </div>
    </header>

    <!-- ── PHASE FILTER ── -->
    <div class="filter-block">
      <span class="filter-label">Filtrar fase</span>
      <div
        class="phase-btns"
        id="phase-filter"
        role="group"
        aria-label="Filtro de fases"
      >
        <button class="phase-btn active" data-phase="all">Todas</button>
        {
          PHASES.map((p) => (
            <button class="phase-btn" data-phase={p.id}>
              {p.name}
            </button>
          ))
        }
      </div>
    </div>

    <!-- ── TABLE ── -->
    <div class="table-wrapper">
      <table class="admin-table" id="admin-table">
        <thead>
          <tr>
            <th>Equipo</th>
            <th id="th-phase">Fase activa</th>
            <th>Estado</th>
            <th>Puntos fase</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="admin-tbody">
          <!-- Rendered by JS below -->
        </tbody>
      </table>
    </div>

    <p class="table-note">
      * Los cambios se guardan en Supabase y se reflejan en el marcador público
      al instante.
    </p>
  </div>

  <!-- ── MODAL REGISTRAR EQUIPO ── -->
  <div
    class="modal-overlay"
    id="modal-register"
    aria-modal="true"
    role="dialog"
    aria-labelledby="modal-title"
  >
    <div class="modal">
      <h2 class="modal-title" id="modal-title">Registrar Equipo</h2>
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label" for="input-name">Nombre del equipo</label>
          <input
            class="form-input"
            id="input-name"
            type="text"
            placeholder="Ej. Los Relámpagos"
            autocomplete="off"
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="input-members"
            >Miembros <small>(separados por coma)</small></label
          >
          <input
            class="form-input"
            id="input-members"
            type="text"
            placeholder="Ana, Carlos, Luis, María, Pedro"
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="input-color">Color del equipo</label>
          <input
            class="form-input form-color"
            id="input-color"
            type="color"
            value="#E8531A"
          />
        </div>
      </div>
      <div class="form-actions">
        <button class="btn btn-ghost" id="btn-modal-cancel">Cancelar</button>
        <button class="btn btn-primary" id="btn-modal-save">Registrar</button>
      </div>
    </div>
  </div>

  <!-- ── TOAST ── -->
  <div class="toast-area" id="toast-area" aria-live="polite"></div>
</BaseLayout>

<script define:vars={{ teamsJson, PHASES }}>
  // ── State from Supabase SSR ───────────────────────────────────────
  let teams = JSON.parse(teamsJson);
  let activePhaseFilter = "all";

  function totalScore(team) {
    return team.phases.reduce((sum, p) => sum + p.points, 0);
  }

  // ── Helpers ──────────────────────────────────────────────────────
  function getDisplayPhaseIdx(team) {
    if (activePhaseFilter !== "all") return activePhaseFilter - 1;
    const doingIdx = team.phases.findIndex((p) => p.status === "doing");
    if (doingIdx >= 0) return doingIdx;
    const lastDone = [...team.phases]
      .map((p, i) => ({ ...p, i }))
      .filter((p) => p.status === "done")
      .at(-1);
    return lastDone ? lastDone.i : 0;
  }

  // ── Render table ─────────────────────────────────────────────────
  function renderTable() {
    const tbody = document.getElementById("admin-tbody");
    const thPhase = document.getElementById("th-phase");

    thPhase.textContent =
      activePhaseFilter === "all"
        ? "Fase activa"
        : PHASES[activePhaseFilter - 1].name;

    if (teams.length === 0) {
      tbody.innerHTML =
        '<tr><td colspan="6" style="text-align:center;padding:2rem;opacity:0.5;font-family:Barlow Condensed,sans-serif;letter-spacing:0.1em">No hay equipos registrados en Supabase.</td></tr>';
      return;
    }

    tbody.innerHTML = teams
      .map((team) => {
        const pi = getDisplayPhaseIdx(team);
        const phase = team.phases[pi];
        const pname = PHASES[pi].name;
        const total = totalScore(team);

        return `
    <tr data-team="${team.id}">
      <td>
        <div class="team-cell">
          <span class="team-dot" style="background:${team.color}"></span>
          <span class="team-cell-name">${team.name}</span>
        </div>
      </td>
      <td class="phase-name-cell">${pname}</td>
      <td>
        <select class="status-select" data-team="${team.id}" data-phase="${phase.phaseId}">
          <option value="pending" ${phase.status === "pending" ? "selected" : ""}>Pendiente</option>
          <option value="doing"   ${phase.status === "doing" ? "selected" : ""}>En curso</option>
          <option value="done"    ${phase.status === "done" ? "selected" : ""}>Completado</option>
        </select>
      </td>
      <td>
        <input
          class="pts-input"
          type="number" min="0" max="999"
          value="${phase.points}"
          data-team="${team.id}"
          data-phase="${phase.phaseId}"
        />
      </td>
      <td>
        <span class="total-display" id="total-${team.id}">${total}</span>
      </td>
      <td>
        <button class="btn btn-save btn-sm save-btn" data-team="${team.id}">Guardar</button>
      </td>
    </tr>`;
      })
      .join("");

    attachTableListeners();
  }

  function attachTableListeners() {
    // Points input → update running total live
    document.querySelectorAll(".pts-input").forEach((input) => {
      input.addEventListener("input", () => {
        const tid = Number(input.dataset.team);
        const pid = Number(input.dataset.phase);
        const team = teams.find((t) => t.id === tid);
        team.phases.find((p) => p.phaseId === pid).points =
          Number(input.value) || 0;
        const el = document.getElementById(`total-${tid}`);
        if (el) el.textContent = String(totalScore(team));
      });
    });

    // Status select
    document.querySelectorAll(".status-select").forEach((sel) => {
      sel.addEventListener("change", () => {
        const tid = Number(sel.dataset.team);
        const pid = Number(sel.dataset.phase);
        const team = teams.find((t) => t.id === tid);
        team.phases.find((p) => p.phaseId === pid).status = sel.value;
      });
    });

    // Save button → call /api/update-score
    document.querySelectorAll(".save-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const tid = Number(btn.dataset.team);
        const team = teams.find((t) => t.id === tid);
        const pi = getDisplayPhaseIdx(team);
        const phase = team.phases[pi];

        btn.textContent = "…";
        btn.disabled = true;

        try {
          const res = await fetch("/api/update-score", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              team_id: tid,
              id_fase: phase.phaseId,
              estatus: phase.status,
              puntos: phase.points,
            }),
          });
          const data = await res.json();
          if (!res.ok) {
            showToast("Error: " + (data.error ?? "Intenta de nuevo"), "error");
          } else {
            btn.textContent = "✓ Guardado";
            btn.classList.add("saved");
            showToast(`${team.name} — Fase ${phase.phaseId} guardada`);
            setTimeout(() => {
              btn.textContent = "Guardar";
              btn.classList.remove("saved");
              btn.disabled = false;
            }, 2000);
            return;
          }
        } catch {
          showToast("Error de red. Intenta de nuevo.", "error");
        }

        btn.textContent = "Guardar";
        btn.disabled = false;
      });
    });
  }

  // ── Phase filter ──────────────────────────────────────────────────
  document.getElementById("phase-filter").addEventListener("click", (e) => {
    const target = e.target;
    if (!target.classList.contains("phase-btn")) return;
    document
      .querySelectorAll(".phase-btn")
      .forEach((b) => b.classList.remove("active"));
    target.classList.add("active");
    activePhaseFilter =
      target.dataset.phase === "all" ? "all" : Number(target.dataset.phase);
    renderTable();
  });

  // ── Register modal ────────────────────────────────────────────────
  const modal = document.getElementById("modal-register");

  document.getElementById("btn-register").addEventListener("click", () => {
    modal.classList.add("open");
    document.getElementById("input-name").focus();
  });

  document
    .getElementById("btn-modal-cancel")
    .addEventListener("click", () => modal.classList.remove("open"));
  modal.addEventListener("click", (e) => {
    if (e.target === modal) modal.classList.remove("open");
  });

  document
    .getElementById("btn-modal-save")
    .addEventListener("click", async () => {
      const nameEl = document.getElementById("input-name");
      const membersEl = document.getElementById("input-members");
      const colorEl = document.getElementById("input-color");

      const name = nameEl.value.trim();
      if (!name) {
        nameEl.focus();
        return;
      }

      const members = membersEl.value
        .split(",")
        .map((m) => m.trim())
        .filter(Boolean);
      const saveBtn = document.getElementById("btn-modal-save");
      saveBtn.textContent = "Guardando…";
      saveBtn.disabled = true;

      try {
        const res = await fetch("/api/create-team", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            nombre: name,
            color: colorEl.value,
            miembros: members,
          }),
        });
        const data = await res.json();
        if (!res.ok) {
          showToast("Error: " + (data.error ?? "Intenta de nuevo"), "error");
        } else {
          // Add to local state
          teams.push({
            id: data.id,
            name,
            color: colorEl.value,
            members,
            phases: [1, 2, 3, 4, 5].map((id) => ({
              phaseId: id,
              status: "pending",
              points: 0,
            })),
          });
          modal.classList.remove("open");
          nameEl.value = "";
          membersEl.value = "";
          renderTable();
          showToast(`Equipo "${name}" registrado`);
        }
      } catch {
        showToast("Error de red.", "error");
      }

      saveBtn.textContent = "Registrar";
      saveBtn.disabled = false;
    });

  // ── Export Excel ──────────────────────────────────────────────────
  document.getElementById("btn-export").addEventListener("click", async () => {
    const XLSX =
      await import("https://cdn.sheetjs.com/xlsx-0.20.2/package/xlsx.mjs");
    const wb = XLSX.utils.book_new();

    const sorted = [...teams].sort((a, b) => totalScore(b) - totalScore(a));
    const rows1 = [
      ["Pos", "Equipo", "Miembros", ...PHASES.map((p) => p.name), "Total"],
    ];
    sorted.forEach((t, i) =>
      rows1.push([
        i + 1,
        t.name,
        t.members.join(", "),
        ...t.phases.map((p) => p.points),
        totalScore(t),
      ]),
    );
    XLSX.utils.book_append_sheet(
      wb,
      XLSX.utils.aoa_to_sheet(rows1),
      "Clasificación",
    );

    const rows2 = [["Equipo", "Fase", "Estado", "Puntos"]];
    teams.forEach((t) =>
      t.phases.forEach((p, i) =>
        rows2.push([t.name, PHASES[i].name, p.status, p.points]),
      ),
    );
    XLSX.utils.book_append_sheet(
      wb,
      XLSX.utils.aoa_to_sheet(rows2),
      "Detalle Fases",
    );

    XLSX.writeFile(wb, `rally-${new Date().toISOString().slice(0, 10)}.xlsx`);
    showToast("Excel exportado");
  });

  // ── Toast ─────────────────────────────────────────────────────────
  function showToast(msg, type = "success") {
    const area = document.getElementById("toast-area");
    const t = document.createElement("div");
    t.className = "toast" + (type === "error" ? " toast-error" : "");
    t.textContent = (type === "error" ? "⚠ " : "✓ ") + msg;
    area.appendChild(t);
    setTimeout(() => t.classList.add("toast-out"), 2600);
    setTimeout(() => t.remove(), 3000);
  }

  // ── Init ──────────────────────────────────────────────────────────
  renderTable();
</script>

<style>
  /* ── Layout ── */
  .admin-view {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  /* ── Header ── */
  .admin-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid rgba(196, 163, 90, 0.18);
  }
  .admin-eyebrow {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--dirt);
    margin-bottom: 0.25rem;
  }
  .admin-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: 2.4rem;
    letter-spacing: 0.08em;
    color: var(--sand);
  }
  .header-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Buttons ── */
  .btn {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.65rem 1.4rem;
    border-radius: 2px;
    cursor: pointer;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.18s;
  }
  .btn-primary {
    background: var(--dirt);
    color: var(--ink);
  }
  .btn-primary:hover {
    background: var(--sand);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(196, 163, 90, 0.3);
  }
  .btn-export {
    background: transparent;
    color: var(--moss-light);
    border: 1px solid var(--moss-light);
  }
  .btn-export:hover {
    background: rgba(74, 92, 58, 0.25);
  }
  .btn-ghost {
    background: transparent;
    color: var(--fog);
    border: 1px solid rgba(255, 255, 255, 0.15);
    opacity: 0.7;
  }
  .btn-ghost:hover {
    opacity: 1;
  }
  .btn-save {
    background: var(--moss);
    color: var(--ash);
    border: 1px solid var(--moss-light);
  }
  .btn-save:hover {
    background: var(--moss-light);
    color: var(--ink);
  }
  .btn-save.saved {
    background: rgba(74, 92, 58, 0.4);
    color: var(--moss-light);
  }
  .btn-sm {
    padding: 0.38rem 0.9rem;
    font-size: 0.75rem;
  }
  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Phase filter ── */
  .filter-block {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }
  .filter-label {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dirt);
    flex-shrink: 0;
  }
  .phase-btns {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .phase-btn {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 2px;
    cursor: pointer;
    background: transparent;
    border: 1px solid rgba(196, 163, 90, 0.2);
    color: var(--fog);
    transition: all 0.18s;
  }
  .phase-btn:hover {
    border-color: var(--dirt);
    color: var(--dirt);
  }
  .phase-btn.active {
    background: rgba(196, 163, 90, 0.14);
    border-color: var(--dirt);
    color: var(--dirt);
  }

  /* ── Table ── */
  .table-wrapper {
    background: rgba(61, 43, 31, 0.4);
    border: 1px solid rgba(196, 163, 90, 0.14);
    border-radius: 4px;
    overflow: hidden;
    overflow-x: auto;
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 620px;
  }
  .admin-table thead {
    background: rgba(0, 0, 0, 0.28);
    border-bottom: 1px solid rgba(196, 163, 90, 0.18);
  }
  .admin-table th {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dirt);
    padding: 0.75rem 1.1rem;
    text-align: left;
    white-space: nowrap;
  }
  .admin-table td {
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    vertical-align: middle;
  }
  .admin-table tr:last-child td {
    border-bottom: none;
  }
  .admin-table tr:hover td {
    background: rgba(196, 163, 90, 0.03);
  }
  .team-cell {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .team-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .team-cell-name {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ash);
  }
  .phase-name-cell {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.82rem;
    color: var(--fog);
    opacity: 0.65;
  }
  .status-select {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.6rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(196, 163, 90, 0.22);
    color: var(--fog);
    border-radius: 2px;
    cursor: pointer;
  }
  .status-select:focus {
    outline: none;
    border-color: var(--dirt);
  }
  .pts-input {
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.35rem;
    width: 72px;
    padding: 0.25rem 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(196, 163, 90, 0.22);
    color: var(--sand);
    text-align: center;
    border-radius: 2px;
  }
  .pts-input:focus {
    outline: none;
    border-color: var(--dirt);
  }
  .total-display {
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.5rem;
    color: var(--sand);
  }
  .table-note {
    font-size: 0.72rem;
    color: rgba(196, 163, 90, 0.35);
    font-family: "Barlow Condensed", sans-serif;
    letter-spacing: 0.05em;
    margin-top: 0.75rem;
  }

  /* ── Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.68);
    backdrop-filter: blur(5px);
    z-index: 50;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .modal-overlay.open {
    display: flex;
  }
  .modal {
    background: var(--earth);
    border: 1px solid rgba(196, 163, 90, 0.22);
    border-top: 3px solid var(--dirt);
    padding: 2rem;
    width: 100%;
    max-width: 520px;
    border-radius: 4px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
  }
  .modal-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.8rem;
    letter-spacing: 0.1em;
    color: var(--sand);
    margin-bottom: 1.4rem;
  }
  .form-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .form-label {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dirt);
  }
  .form-label small {
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.6;
  }
  .form-input {
    font-family: "Barlow", sans-serif;
    font-size: 0.95rem;
    padding: 0.6rem 0.85rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(196, 163, 90, 0.2);
    color: var(--ash);
    border-radius: 2px;
