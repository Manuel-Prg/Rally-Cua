---
// src/pages/admin.astro  —  Panel de control
import BaseLayout from "../layouts/BaseLayout.astro";
import { PHASES, totalScore } from "../lib/mockData";
import { supabase } from "../db/supabase.js";

import AdminDashboard from "../components/AdminDashboard";

const MAX_TEAMS = 10;

// ── Fetch teams + scores from Supabase ──────────────────────────
let rawTeams: any[] = [];
try {
  const { data, error } = await supabase
    .from("teams")
    .select("id, name, color, members, scores(phase_id, status, points)")
    .order("id");
  if (error) {
    console.error("Admin fetch error:", error);
  } else {
    rawTeams = data || [];
  }
} catch (e) {
  console.error("Fetch exception in admin.astro:", e);
}

const teams = (rawTeams ?? []).map((row: any) => ({
  id: row.id,
  name: row.name,
  color: row.color,
  members: Array.isArray(row.members) ? row.members : [],
  phases: [1, 2, 3, 4, 5].map((phaseId) => {
    const s = (row.scores ?? []).find((sc: any) => sc.phase_id === phaseId);
    return { phaseId, status: s?.status ?? "pending", points: s?.points ?? 0 };
  }),
}));

// ── Fetch pending registrations ──────────────────────────────────
let registrations: any[] = [];
try {
  const { data: regs, error: regErr } = await supabase
    .from("registrations")
    .select("id, team_name, representative, created_at")
    .is("approved_at", null)
    .order("created_at", { ascending: true });
  if (!regErr && regs) {
    registrations = regs;
  }
} catch (e) {
  console.error("Fetch registrations error:", e);
}

// Serialize for client script
const teamsJson = JSON.stringify(teams);
const registrationsJson = JSON.stringify(registrations);
const teamCount = teams.length;
---

<BaseLayout title="Panel Admin" activePage="admin">
  <div class="admin-view">
    <AdminDashboard 
      initialTeams={teams} 
      initialRegistrations={registrations} 
      maxTeams={MAX_TEAMS}
      client:load 
    />
  </div>
</BaseLayout>

<style>
  .admin-view {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
</style>
